# =============================================================================
# Campus Plug — Environment Configuration
# Copy to .env and fill in your production values
# =============================================================================

# Flask app settings
# Generate a strong key with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="change-me-in-production"

# For PostgreSQL in production (Render provides this):
# DATABASE_URL="postgresql://user:password@host:5432/campus_plug"
# For local dev (default):
DATABASE_URL="sqlite:///campus_plug.db"

FLASK_ENV="development"
# Set to "production" before deploying to Render

HOST="0.0.0.0"
PORT="5000"

# Public URL for self-referential links and payment callbacks
# In production, set to your Render app URL (e.g. https://campus-plug.onrender.com)
APP_URL="http://127.0.0.1:5000"

# Mail settings for notification emails — use SendGrid, Mailgun, or Gmail App Password
MAIL_USERNAME=""
MAIL_PASSWORD=""
MAIL_DEFAULT_SENDER="noreply@campusplug.com"
MAIL_SERVER="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USE_TLS="true"

# Paystack API keys — use live keys in production
PAYSTACK_SECRET_KEY="sk_test_your_secret_key_here"
PAYSTACK_PUBLIC_KEY="pk_test_your_public_key_here"

# Production only: set SESSION_COOKIE_SECURE to true
# Not needed in dev — handled automatically by ProductionConfig
