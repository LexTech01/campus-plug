# Flask app settings
SECRET_KEY="change-me-in-production"
DATABASE_URL="sqlite:///campus_plug.db"
FLASK_ENV="development"
HOST="127.0.0.1"
PORT="5000"

# Public URL for self-referential links and payment callbacks
APP_URL="http://127.0.0.1:5000"

# Resend API key for transactional emails (sign up at https://resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Paystack API keys for MoMo and card transaction processing with escrow
# Get test keys from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""
