# =============================================================================
# Campus Plug — Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# Flask app settings
# Generate a strong key:   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="change-me-in-production"

# Database — PostgreSQL in production, SQLite locally
# Production example:
#   DATABASE_URL="postgresql://user:password@host:5432/campus_plug"
# Local dev (default):
DATABASE_URL="sqlite:///campus_plug.db"

FLASK_ENV="development"
# Set to "production" before deploying

HOST="0.0.0.0"
PORT="5000"

# Public URL for payment callbacks and self-referential links
# Production: https://your-app.onrender.com
APP_URL="http://127.0.0.1:5000"

# Resend API key for transactional emails (recommendations, password reset)
# Get your API key at https://resend.com
RESEND_API_KEY="re_..."

# Paystack API keys — use live keys in production
PAYSTACK_SECRET_KEY="sk_test_your_secret_key_here"
PAYSTACK_PUBLIC_KEY="pk_test_your_public_key_here"

# Set to "1" to skip auto-migration/table creation on startup
# SKIP_DB_CREATE="0"
